<?xml version="1.0" encoding="UTF-8"?>
<!--
  Secbox Sentinel installer (WiX v5).

  Installs the Windows Service that performs ETW-based kernel monitoring on
  behalf of the in-editor Secbox.Core client. Per-machine install under
  Program Files. Service registered as "SecboxSentinel", runs as LocalSystem
  (required for kernel ETW sessions), starts automatically with the OS.

  Component design:
   * ServiceExe        — holds SecboxSentinel.exe as KeyPath + ServiceInstall +
                         ServiceControl + util:ServiceConfig. MSI REQUIRES the
                         service binary to be the KeyPath of the same Component
                         that owns ServiceInstall; otherwise InstallServices
                         silently no-ops (no ImagePath to register).
   * SentinelPayload   — auto-harvested via <Files Exclude=...> for every
                         other file under the publish output. Excludes the
                         service exe (already declared in ServiceExe) to
                         avoid the duplicate-File ICE03 error.
   * EventLogRegistration — pre-creates the Event Log source so the service's
                         first emit doesn't trip the "source does not exist"
                         path that requires admin to fix.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Secbox Sentinel"
           Manufacturer="secbox"
           Version="0.1.0.0"
           UpgradeCode="d8a64db3-9a3f-4b1f-9d80-1b87f4d3a601"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Secbox Sentinel is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!--
      ARP icon (Programs and Features). Drop a multi-resolution .ico file
      named SecboxSentinel.ico in this project directory and the build
      picks it up. WiX bundles the icon into the MSI; Windows shows it in
      Settings → Apps and in the Control Panel uninstall list.

      Icon spec: .ico container with 16×16, 32×32, 48×48, and 256×256
      sizes embedded. 32-bit color + alpha channel.
    -->
    <Icon Id="SecboxSentinelIcon" SourceFile="SecboxSentinel.ico" />
    <Property Id="ARPPRODUCTICON" Value="SecboxSentinelIcon" />

    <!--
      UI bitmaps. WixUI_Minimal is the smallest dialog set that still
      renders branding: one combined welcome+install dialog with the
      banner across the top and the welcome bitmap on the left.

      NOTE: these only render when msiexec runs in full UI mode. The
      adapter's RunInstaller currently uses /qb+ (basic UI), which
      bypasses these dialogs. The bitmaps stay embedded in the MSI
      regardless — anyone who double-clicks the MSI directly sees them.
      Drop /qb+ from the msiexec args in SentinelInstaller.RunInstaller
      if you want the branded UI during the in-editor install flow.
    -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="welcome.bmp" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="SECBOX_ROOT" Name="Secbox">
        <Directory Id="INSTALLFOLDER" Name="Sentinel" />
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Secbox Sentinel" Level="1">
      <!-- Hand-authored: service exe + ServiceInstall + recovery actions. -->
      <ComponentRef Id="ServiceExe" />
      <!-- Auto-harvested via <Files> globs below (covers everything except .exe). -->
      <ComponentGroupRef Id="SentinelPayload" />
      <ComponentRef Id="EventLogRegistration" />
    </Feature>

    <!--
      WiX 5's <Files> element does NOT support Exclude. Workaround: explicit
      per-extension globs that collectively cover the publish output minus
      the .exe (which lives in the hand-authored ServiceExe component above).
      Publish output is: *.dll, *.json, *.pdb, *.exe at root + amd64/, arm64/,
      x86/ native subdirs. If a future .NET version adds new file types here,
      this list needs updating.
    -->
    <ComponentGroup Id="SentinelPayload" Directory="INSTALLFOLDER">
      <Files Include="$(var.HarvestFolder)\*.dll" />
      <Files Include="$(var.HarvestFolder)\*.json" />
      <Files Include="$(var.HarvestFolder)\*.pdb" />
      <Files Subdirectory="amd64" Include="$(var.HarvestFolder)\amd64\**" />
      <Files Subdirectory="arm64" Include="$(var.HarvestFolder)\arm64\**" />
      <Files Subdirectory="x86" Include="$(var.HarvestFolder)\x86\**" />
    </ComponentGroup>

    <DirectoryRef Id="INSTALLFOLDER">
      <!--
        The service exe MUST be the KeyPath of the Component holding
        ServiceInstall — MSI uses the KeyPath file to derive the service's
        ImagePath. Without this anchoring InstallServices silently no-ops
        and the subsequent util:ServiceConfig fails with 0x80070424
        "Service does not exist".
      -->
      <Component Id="ServiceExe" Guid="3e1d4a85-2f9c-4eb8-95a3-c97f0e842110">
        <File Id="SecboxSentinelExe"
              Source="$(var.HarvestFolder)\SecboxSentinel.exe"
              KeyPath="yes" />

        <ServiceInstall Id="SecboxSentinelService"
                        Name="SecboxSentinel"
                        DisplayName="Secbox Sentinel"
                        Description="Kernel-level monitoring (file/process/network/registry) for the s&amp;box editor. Detection-only; all decisions stay in user-mode. Disable or uninstall from secbox in the editor."
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Vital="yes"
                        Account="LocalSystem" />

        <!--
          util:ServiceConfig as a Component-level sibling (not nested in
          ServiceInstall) so its deferred CA schedules after the standard
          InstallServices action has registered the service. Nesting it
          inside ServiceInstall triggers the WiX 5 ordering bug.
        -->
        <util:ServiceConfig ServiceName="SecboxSentinel"
                            FirstFailureActionType="restart"
                            SecondFailureActionType="restart"
                            ThirdFailureActionType="none"
                            RestartServiceDelayInSeconds="10"
                            ResetPeriodInDays="1" />

        <ServiceControl Id="SecboxSentinelServiceControl"
                        Name="SecboxSentinel"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="EventLogRegistration" Guid="b9c0e7a1-3d22-4ad9-9c1a-7e2f0b8f9112">
        <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\SecboxSentinel">
          <RegistryValue Type="integer" Name="TypesSupported" Value="7" />
        </RegistryKey>
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\secbox\Sentinel\EventLog"
                       Name="Registered"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Package>

</Wix>
