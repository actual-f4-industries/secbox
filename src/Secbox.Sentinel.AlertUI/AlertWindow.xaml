<Window x:Class="Secbox.Sentinel.AlertUI.AlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="secbox — runtime detection"
        Width="668" Height="468"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="12">

  <!-- Transparent margin gives the drop shadow room to render. The window is
       fully transparent (AllowsTransparency=True); everything visible is drawn
       below, so there's no DWM frame to leak a white top line. -->
  <Grid Margin="14" Background="Transparent">
    <!-- Shadow caster: an empty filled rectangle behind the content. Keeping the
         DropShadowEffect on a bare shape (not the whole tree) means the blur
         pipeline processes one rectangle and the content above stays crisp. -->
    <Border Background="{StaticResource Background}">
      <Border.Effect>
        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.6" Color="Black" />
      </Border.Effect>
    </Border>

    <!-- Content + 1px brand edge (native frame is gone — WindowStyle=None). -->
    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" Background="{StaticResource Background}">
    <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- custom title bar -->
      <RowDefinition Height="Auto" />  <!-- severity banner -->
      <RowDefinition Height="*" />     <!-- body -->
      <RowDefinition Height="Auto" />  <!-- footer -->
    </Grid.RowDefinitions>

    <!-- Custom branded title bar (replaces native chrome). Drag anywhere to
         move the window; ✕ closes, which exits 0 = Block (the fail-safe). -->
    <Border Grid.Row="0"
            Background="{StaticResource Surface}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <Grid Height="48">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
          <Image Source="/Assets/secbox-logo.png"
                 Width="50" Height="50"
                 RenderOptions.BitmapScalingMode="HighQuality"
                 VerticalAlignment="Center" />
          <TextBlock Text="SECBOX"
                     FontFamily="/Assets/#Finlandica Headline"
                     Foreground="{StaticResource Text}"
                     FontSize="19"
                     Margin="9,3,0,1"
                     VerticalAlignment="Center" />
          <TextBlock Text="runtime interception"
                     Foreground="{StaticResource TextDim}"
                     FontSize="11"
                     Margin="8,0,0,0"
                     VerticalAlignment="Center" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="&#x2715;"
                Width="46"
                Style="{StaticResource TitleBarButton}"
                ToolTip="Close (blocks the intercepted action)"
                Click="Close_Click" />
      </Grid>
    </Border>

    <!-- Banner -->
    <Border Grid.Row="1" Background="{StaticResource Danger}" Padding="16,14">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="⚠" Foreground="White" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center" />
        <StackPanel>
          <TextBlock Text="Critical runtime detection"
                     Foreground="White" FontSize="16" FontWeight="Bold" />
          <TextBlock x:Name="SubtitleText"
                     Text="A library-attributed action was intercepted."
                     Foreground="{StaticResource DangerLight}" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="2" Margin="18,16,18,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="{StaticResource Surface}"
              BorderBrush="{StaticResource Border}"
              BorderThickness="1"
              Padding="14,12"
              CornerRadius="2"
              Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Action"     Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ActionText"
                     Foreground="{StaticResource DangerLight}" FontWeight="SemiBold" Margin="0,0,0,4" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Event"      Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="1" Grid.Column="1" x:Name="KindText"
                     Foreground="{StaticResource Text}" FontFamily="Consolas" Margin="0,0,0,4" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Target"     Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TargetText"
                     Foreground="{StaticResource Text}" FontFamily="Consolas"
                     TextWrapping="Wrap" Margin="0,0,0,4" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Library"    Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LibraryText"
                     Foreground="{StaticResource DangerLight}" FontFamily="Consolas"
                     FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Time"       Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TimeText"
                     Foreground="{StaticResource Text}" Margin="0,0,0,4" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="PID" Foreground="{StaticResource TextDim}" />
          <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PidText"
                     Foreground="{StaticResource Text}" />
        </Grid>
      </Border>

      <TextBox Grid.Row="1"
               x:Name="NoteBox"
               IsReadOnly="True"
               Background="{StaticResource Surface}"
               Foreground="{StaticResource TextDim}"
               BorderBrush="{StaticResource Border}"
               BorderThickness="1"
               FontFamily="Consolas"
               FontSize="11"
               Padding="12,10"
               VerticalScrollBarVisibility="Auto"
               TextWrapping="Wrap" />
    </Grid>

    <!-- Footer — two layouts, one shown depending on action mode -->
    <Border Grid.Row="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
      <Grid Margin="16,12">
        <!--
          DecisionPanel: shown when action=="Suspended". The library
          thread is blocked waiting for our exit code. Four buttons:
            Allow (1) — let this call through, prompt again next time
            Allow & Trust (2) — let through + persist library to trust list
            Kill (3) — Environment.Exit(1) the editor
            Kill & Remove library (4) — Exit(1) the editor + delete the
              offending library folder from disk (locked files finish on
              the next editor start)
          Closing the window (✕) without clicking → exit code 0 = Block.
        -->
        <StackPanel x:Name="DecisionPanel"
                    Orientation="Vertical"
                    Visibility="Collapsed">
          <TextBlock Text="The editor's calling thread is SUSPENDED. The library cannot continue until you choose."
                     Foreground="{StaticResource DangerLight}"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnAllow"
                    Content="Allow once"
                    Margin="0,0,8,0"
                    Click="Allow_Click" />
            <Button x:Name="BtnAllowTrust"
                    Content="Allow &amp; Trust library"
                    Margin="0,0,8,0"
                    Click="AllowTrust_Click" />
            <Button x:Name="BtnKill"
                    Content="Kill editor"
                    Margin="0,0,8,0"
                    Style="{StaticResource DangerButton}"
                    Click="Kill_Click" />
            <Button x:Name="BtnKillRemove"
                    Content="Kill &amp; remove library"
                    ToolTip="Terminates the editor and deletes the offending library from this project's Libraries folder. Files locked right now are removed when the editor next starts."
                    Style="{StaticResource DangerButton}"
                    Click="KillRemove_Click" />
          </StackPanel>
        </StackPanel>

        <!-- DismissPanel: shown for already-resolved findings (action="Blocked" or "Detected") -->
        <Grid x:Name="DismissPanel" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="Full audit trail: %LOCALAPPDATA%\secbox\sentinel-events.log"
                     Foreground="{StaticResource TextDim}"
                     FontFamily="Consolas"
                     FontSize="11"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="Dismiss"
                  Style="{StaticResource DangerButton}"
                  Click="Dismiss_Click" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
  </Border>
  </Grid>
</Window>
