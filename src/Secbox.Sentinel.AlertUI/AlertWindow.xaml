<Window x:Class="Secbox.Sentinel.AlertUI.AlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="secbox — runtime detection"
        Width="640" Height="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize"
        Background="{StaticResource Background}"
        FontFamily="Segoe UI"
        FontSize="12">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Banner -->
    <Border Grid.Row="0" Background="{StaticResource Danger}" Padding="16,14">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="⚠" Foreground="White" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center" />
        <StackPanel>
          <TextBlock Text="Critical runtime detection"
                     Foreground="White" FontSize="16" FontWeight="Bold" />
          <TextBlock x:Name="SubtitleText"
                     Text="A library-attributed action was intercepted."
                     Foreground="{StaticResource DangerLight}" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="1" Margin="18,16,18,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="{StaticResource Surface}"
              BorderBrush="{StaticResource Border}"
              BorderThickness="1"
              Padding="14,12"
              CornerRadius="2"
              Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Action"     Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ActionText"
                     Foreground="{StaticResource DangerLight}" FontWeight="SemiBold" Margin="0,0,0,4" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Event"      Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="1" Grid.Column="1" x:Name="KindText"
                     Foreground="{StaticResource Text}" FontFamily="Consolas" Margin="0,0,0,4" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Target"     Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TargetText"
                     Foreground="{StaticResource Text}" FontFamily="Consolas"
                     TextWrapping="Wrap" Margin="0,0,0,4" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Library"    Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LibraryText"
                     Foreground="{StaticResource DangerLight}" FontFamily="Consolas"
                     FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Time"       Foreground="{StaticResource TextDim}" Margin="0,0,0,4" />
          <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TimeText"
                     Foreground="{StaticResource Text}" Margin="0,0,0,4" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Editor PID" Foreground="{StaticResource TextDim}" />
          <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PidText"
                     Foreground="{StaticResource Text}" />
        </Grid>
      </Border>

      <TextBox Grid.Row="1"
               x:Name="NoteBox"
               IsReadOnly="True"
               Background="{StaticResource Surface}"
               Foreground="{StaticResource TextDim}"
               BorderBrush="{StaticResource Border}"
               BorderThickness="1"
               FontFamily="Consolas"
               FontSize="11"
               Padding="12,10"
               VerticalScrollBarVisibility="Auto"
               TextWrapping="Wrap" />
    </Grid>

    <!-- Footer — two layouts, one shown depending on action mode -->
    <Border Grid.Row="2" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
      <Grid Margin="16,12">
        <!--
          DecisionPanel: shown when action=="Suspended". The library
          thread is blocked waiting for our exit code. Four buttons:
            Allow (1) — let this call through, prompt again next time
            Allow & Trust (2) — let through + persist library to trust list
            Kill (3) — Environment.Exit(1) the editor
            Kill & Remove library (4) — disabled placeholder
          Closing the window without clicking → exit code 0 = Block.
        -->
        <StackPanel x:Name="DecisionPanel"
                    Orientation="Vertical"
                    Visibility="Collapsed">
          <TextBlock Text="The editor's calling thread is SUSPENDED. The library cannot continue until you choose."
                     Foreground="{StaticResource DangerLight}"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnAllow"
                    Content="Allow once"
                    Margin="0,0,8,0"
                    Click="Allow_Click" />
            <Button x:Name="BtnAllowTrust"
                    Content="Allow &amp; Trust library"
                    Margin="0,0,8,0"
                    Click="AllowTrust_Click" />
            <Button x:Name="BtnKill"
                    Content="Kill editor"
                    Margin="0,0,8,0"
                    Style="{StaticResource DangerButton}"
                    Click="Kill_Click" />
            <Button x:Name="BtnKillRemove"
                    Content="Kill &amp; remove library"
                    IsEnabled="False"
                    ToolTip="Not implemented yet — coming in a future release"
                    Style="{StaticResource DangerButton}"
                    Click="KillRemove_Click" />
          </StackPanel>
        </StackPanel>

        <!-- DismissPanel: shown for already-resolved findings (action="Blocked" or "Detected") -->
        <Grid x:Name="DismissPanel" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="Full audit trail: %LOCALAPPDATA%\secbox\sentinel-events.log"
                     Foreground="{StaticResource TextDim}"
                     FontFamily="Consolas"
                     FontSize="11"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="Dismiss"
                  Style="{StaticResource DangerButton}"
                  Click="Dismiss_Click" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
